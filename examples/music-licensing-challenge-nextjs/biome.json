{
	"$schema": "https://biomejs.dev/schemas/1.9.4/schema.json",
	"vcs": {
		"enabled": false,
		"clientKind": "git",
		"useIgnoreFile": false
	},
	"files": {
		"ignoreUnknown": false,
		"ignore": [".next"],
		"include": ["**/*.js", "**/*.jsx", "**/*.ts", "**/*.tsx", "**/*.css"]
	},
	"formatter": {
		"enabled": true,
		"indentStyle": "tab"
	},
	"organizeImports": {
		"enabled": true
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true,
			"suspicious": {
				"noArrayIndexKey": "warn"
			},
			"a11y": {
				"useAltText": "warn",
				"useValidAnchor": "warn",
				"noSvgWithoutTitle": "warn"
			},
			"complexity": {
				"noExtraBooleanCast": "warn"
			},
			"correctness": {
				"noUnusedVariables": "error",
				"noUnusedImports": "error"
			}
		}
	},
	"javascript": {
		"formatter": {
			"arrowParentheses": "always",
			"bracketSameLine": false,
			"bracketSpacing": true,
			"semicolons": "always",
			"trailingCommas": "all",
			"jsxQuoteStyle": "double",
			"quoteProperties": "asNeeded",
			"lineWidth": 80,
			"indentWidth": 2
		}
	}
}
